# Runtime
FLASK_ENV=production
FLASK_DEBUG=false
PORT=5000

# Required on Railway
DATABASE_URL=
REDIS_URL=
SECRET_KEY=

# Optional tuning
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
LOG_LEVEL=INFO
LOG_FILE=
CORS_ORIGINS=*

# WhatsApp provider selection
WHATSAPP_PROVIDER=twilio
WHATSAPP_ENABLED=true
WHATSAPP_SANDBOX_MODE=true

# Twilio WhatsApp (if provider=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Meta WhatsApp (if provider=meta)
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_APP_SECRET=

# Auth/JWT
JWT_SECRET=
OTP_PROVIDER=twilio
OTP_LENGTH=6
OTP_VALIDITY_MINUTES=10

# Business metadata
COMPANY_NAME=Inventory Business
COMPANY_PHONE=
COMPANY_EMAIL=
ADMIN_PHONE_NUMBERS=
CLIENT_PHONE_NUMBERS=
