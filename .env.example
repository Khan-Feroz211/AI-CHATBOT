# Environment configuration for BazaarBot
# Copy this file to .env and fill in your values

# ── Flask ──────────────────────────────────
# CHANGE THIS IN PRODUCTION — use a long random string
SECRET_KEY=change-me-to-a-random-string

# Dashboard login password
ADMIN_PASSWORD=bazaar123

# 0.0.0.0 port
PORT=5000

# Set to "true" to enable Flask debug mode (development only)
DEBUG=false

# ── Database ───────────────────────────────
DATABASE_PATH=bazaarbot.db

# ── Twilio WhatsApp ─────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta-style webhook verify token (optional)
WEBHOOK_VERIFY_TOKEN=my_secret_token

# ── Email (SMTP) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Default notification email for the default tenant
NOTIFY_EMAIL=owner@yourshop.pk

# ── Multi-tenant ────────────────────────────
# Slug of the default tenant (created by --setup-tenant)
DEFAULT_TENANT=default

# ── Rate limiting ───────────────────────────
RATE_LIMIT=30 per minute
