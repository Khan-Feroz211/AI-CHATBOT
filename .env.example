# Environment configuration for BazaarBot
# Copy this file to .env and fill in your values

# ── Flask / server ──────────────────────────
# CHANGE THIS IN PRODUCTION — use a long random string
SECRET_KEY=change-me-to-a-random-string

# Dashboard login password
ADMIN_PASSWORD=bazaar123

# 0.0.0.0 port
PORT=5000

# Set to "true" to enable Flask/uvicorn debug/reload mode (development only)
DEBUG=false

# ── SQLite (legacy — used by tests and Flask backend) ──
DATABASE_PATH=bazaarbot.db

# ── PostgreSQL (FastAPI / Day 2+) ──────────────────────
# asyncpg URL format
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bazaarbot
DATABASE_POOL_SIZE=10

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT auth ────────────────────────────────────────────
JWT_SECRET=change-this-in-production
JWT_EXPIRE_HOURS=24
API_KEY_HEADER=X-API-Key

# ── Super-admin bootstrap (first run only) ──────────────
SUPERADMIN_EMAIL=admin@yourshop.pk
SUPERADMIN_PASSWORD=change-me

# ── Twilio WhatsApp ─────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta-style webhook verify token (optional)
WEBHOOK_VERIFY_TOKEN=my_secret_token

# ── Email (SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Default notification email for the default tenant
NOTIFY_EMAIL=owner@yourshop.pk

# ── Multi-tenant ─────────────────────────────────────────
# Slug of the default tenant (created by --setup-tenant)
DEFAULT_TENANT=default

# ── Rate limiting ─────────────────────────────────────────
RATE_LIMIT=30 per minute

# ── Backend toggle ────────────────────────────────────────
# "flask" (default) or "fastapi"
APP_BACKEND=flask

# ── NLP upgrade (optional — Day 3) ───────────────────────
# LLM fallback: generates contextual responses for low-confidence queries.
# Leave USE_LLM_FALLBACK=false to use TF-IDF-only mode (no API key needed).
USE_LLM_FALLBACK=false

# LLM provider: "openai", "groq", or "none"
# Groq is recommended for Pakistan (faster + cheaper than OpenAI).
# Get a free key at https://console.groq.com
LLM_PROVIDER=none

# API key for the selected provider.
# OpenAI key  → https://platform.openai.com/api-keys
# Groq key    → https://console.groq.com/keys
LLM_API_KEY=

# Cosine-similarity confidence threshold below which the LLM fallback fires.
# Queries with TF-IDF score >= this value are answered by the intent router.
LLM_CONFIDENCE_THRESHOLD=0.30

# Maximum tokens the LLM may generate per response.
LLM_MAX_TOKENS=300

# LangChain semantic RAG: uses FAISS + sentence-transformers for richer context.
# Set true to enable.  Downloads the ~90 MB embedding model on first run.
USE_LANGCHAIN_RAG=false

# HuggingFace model used for local embeddings (no API key required).
LANGCHAIN_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── JazzCash (Pakistan mobile payment — Day 7) ───────────────────────────
# Obtain credentials from the JazzCash merchant portal.
# Sandbox dashboard: https://sandbox.jazzcash.com.pk
# Live dashboard:    https://payments.jazzcash.com.pk
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=

# ── Easypaisa (Telenor mobile payment — Day 7) ───────────────────────────
# Obtain credentials from the Easypaisa developer / merchant portal.
# Sandbox dashboard: https://easypay.easypaisa.com.pk
# Live dashboard:    https://easypaisa.com.pk/easypay
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_NTN=

# ── Billing / Frontend (Day 7) ───────────────────────────────────────────
# Base URL for the frontend SPA.  Payment gateway callbacks redirect here.
# Development:  http://localhost:5173
# Production:   https://yourdomain.pk
FRONTEND_URL=http://localhost:5173

# App environment — controls gateway sandbox vs live mode.
# Values: "production" (live payments) | anything else (sandbox).
APP_ENV=sandbox
