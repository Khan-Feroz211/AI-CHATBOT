# Application Settings
APP_NAME=AI Chatbot ML
APP_VERSION=3.0.0
ENVIRONMENT=development
DEBUG=true

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite:///./chatbot_data/chatbot.db

# Security - CHANGE THESE!
SECRET_KEY=your-secret-key-here-change-this-to-random-32-chars
ENCRYPTION_KEY=your-encryption-key-change-this-32-chars-min

# ===== TWILIO WHATSAPP CONFIGURATION =====
WHATSAPP_PROVIDER=twilio
WHATSAPP_ENABLED=true
WHATSAPP_SANDBOX_MODE=true
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Admin & Security
ADMIN_PHONE_NUMBER=+92XXXXXXXXXX
WEBHOOK_VERIFY_TOKEN=your-verify-token-here
MFA_ISSUER_NAME=AI Business Bot
VALIDATE_TWILIO=false
PORT=5000
