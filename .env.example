# Application Settings
APP_NAME=AI Chatbot ML
APP_VERSION=3.0.0
ENVIRONMENT=development
DEBUG=false

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite:///./chatbot_data/chatbot.db

# Colab Integration (update when Colab is running)
COLAB_API_URL=
COLAB_API_KEY=
COLAB_ENABLED=false
DETECT_ACCELERATOR_DEVICE=false

# Security (change this!)
SECRET_KEY=your-secret-key-here-change-this

# Payments (Pakistan)
PAYMENT_SANDBOX_MODE=true
PAYMENT_WEBHOOK_SECRET=

# JazzCash
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=
JAZZCASH_WEBHOOK_SECRET=

# EasyPaisa
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_RETURN_URL=
EASYPAISA_WEBHOOK_SECRET=

# Bank Transfer
BANK_TRANSFER_BANK_NAME=
BANK_TRANSFER_ACCOUNT_TITLE=
BANK_TRANSFER_IBAN=

# WhatsApp (Meta Cloud API)
WHATSAPP_ENABLED=false
WHATSAPP_SANDBOX_MODE=true
WHATSAPP_API_VERSION=v22.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_TIMEOUT_SECONDS=15
WHATSAPP_MAX_RETRIES=2
WHATSAPP_RETRY_BACKOFF_SECONDS=1.0
