# Application Settings
APP_NAME=AI Chatbot ML
APP_VERSION=3.0.0
ENVIRONMENT=development
DEBUG=false

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite:///./chatbot_data/chatbot.db

# Colab Integration (update when Colab is running)
COLAB_API_URL=
COLAB_API_KEY=
