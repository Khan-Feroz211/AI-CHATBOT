# Environment configuration for BazaarBot — Docker deployment
# Copy this file to .env.docker and fill in your values.
# Never commit the populated .env.docker to version control.

# ── Flask / server ──────────────────────────────────────
# CHANGE THIS IN PRODUCTION — use a long random string
SECRET_KEY=change-me-to-a-random-string

# Dashboard login password
ADMIN_PASSWORD=bazaar123

# Port exposed by the app container (mapped in docker-compose.yml)
PORT=8000

# Set to "true" to enable debug/reload mode (development only)
DEBUG=false

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=choose-strong-password
POSTGRES_DB=bazaarbot

# Full asyncpg connection URL (auto-composed by docker-compose.yml from above)
# Override here if your DB lives outside the Docker stack.
DATABASE_URL=postgresql+asyncpg://postgres:choose-strong-password@postgres:5432/bazaarbot
DATABASE_POOL_SIZE=10

# ── Redis + Celery ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# Celery broker / result backend default to REDIS_URL when left empty
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Set to "true" only in tests — runs tasks synchronously without a worker
CELERY_TASK_ALWAYS_EAGER=false

# ── App ──────────────────────────────────────────────────
# "flask" (legacy) or "fastapi" (Day 2+)
APP_BACKEND=fastapi

# ── JWT auth ─────────────────────────────────────────────
JWT_SECRET=change-this-in-production
JWT_EXPIRE_HOURS=24
API_KEY_HEADER=X-API-Key

# ── Super-admin bootstrap (first run only) ───────────────
SUPERADMIN_EMAIL=admin@yourshop.pk
SUPERADMIN_PASSWORD=change-me

# ── Twilio WhatsApp ──────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta-style webhook verify token (optional)
WEBHOOK_VERIFY_TOKEN=my_secret_token

# ── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Default notification email for the default tenant
NOTIFY_EMAIL=owner@yourshop.pk

# ── Multi-tenant ─────────────────────────────────────────
DEFAULT_TENANT=default

# ── Rate limiting ─────────────────────────────────────────
RATE_LIMIT=30 per minute

# ── NLP upgrade (optional — Day 3) ───────────────────────
USE_LLM_FALLBACK=false
LLM_PROVIDER=none
LLM_API_KEY=
LLM_CONFIDENCE_THRESHOLD=0.30
LLM_MAX_TOKENS=300
USE_LANGCHAIN_RAG=false
LANGCHAIN_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
